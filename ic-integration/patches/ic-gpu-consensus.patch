+/// GPU batch accumulator for BLS verification.
+/// Collects (sig, pk, msg) tuples and flushes to GPU on demand.
+#[allow(dead_code)]
+pub mod gpu_batch {
+    use super::*;
+    use std::cell::RefCell;
+    use std::sync::atomic::{AtomicBool, AtomicU64, Ordering};
+
+    static GPU_ENABLED: AtomicBool = AtomicBool::new(false);
+    static GPU_INIT_DONE: AtomicBool = AtomicBool::new(false);
+    static VERIFY_COUNT: AtomicU64 = AtomicU64::new(0);
+    static VERIFY_TOTAL_NS: AtomicU64 = AtomicU64::new(0);
+    static GPU_BATCH_COUNT: AtomicU64 = AtomicU64::new(0);
+    static GPU_BATCH_TOTAL_NS: AtomicU64 = AtomicU64::new(0);
+
+    fn ensure_gpu_init() {
+        if !GPU_INIT_DONE.swap(true, Ordering::Relaxed) {
+            match gpu_crypto::init() {
+                Ok(()) => {
+                    GPU_ENABLED.store(true, Ordering::Relaxed);
+                    eprintln!("[GPU-CRYPTO] GPU initialized for BLS batch verification");
+                }
+                Err(e) => {
+                    eprintln!("[GPU-CRYPTO] GPU not available: {e:?}, using CPU");
+                }
+            }
+        }
+    }
+
+    /// Returns true if GPU is available for BLS batch verification.
+    pub fn gpu_available() -> bool {
+        ensure_gpu_init();
+        GPU_ENABLED.load(Ordering::Relaxed)
+    }
+
+    struct BatchItem {
+        sig: G1Affine,
+        pk: G2Affine,
+        msg: G1Affine,
+    }
+
+    thread_local! {
+        static BATCH: RefCell<Vec<BatchItem>> = RefCell::new(Vec::new());
+    }
+
+    /// Begin a GPU batch verification session.
+    /// After this call, use `queue_verify` to add items,
+    /// then `flush_batch` to get results.
+    pub fn begin_batch() {
+        BATCH.with(|b| b.borrow_mut().clear());
+    }
+
+    /// Queue a BLS verification for batch processing.
+    /// Returns the index in the batch.
+    pub fn queue_verify(signature: &G1Affine, public_key: &G2Affine, message: &G1Affine) -> usize {
+        BATCH.with(|b| {
+            let mut batch = b.borrow_mut();
+            let idx = batch.len();
+            batch.push(BatchItem {
+                sig: signature.clone(),
+                pk: public_key.clone(),
+                msg: message.clone(),
+            });
+            idx
+        })
+    }
+
+    /// Flush the batch — verify all queued items via GPU (or CPU fallback).
+    /// Returns Vec<bool> with verification results.
+    pub fn flush_batch() -> Vec<bool> {
+        ensure_gpu_init();
+
+        BATCH.with(|b| {
+            let batch = b.borrow();
+            if batch.is_empty() {
+                return vec![];
+            }
+
+            let start = std::time::Instant::now();
+            let batch_size = batch.len();
+
+            let results = if GPU_ENABLED.load(Ordering::Relaxed) && batch_size > 1 {
+                // GPU batch path — only used when we have multiple items
+                let items: Vec<(&G1Affine, &G2Affine, &G1Affine)> = batch
+                    .iter()
+                    .map(|item| (&item.sig, &item.pk, &item.msg))
+                    .collect();
+                verify_bls_signature_batch_gpu(&items)
+            } else {
+                // CPU path — single items or no GPU
+                batch
+                    .iter()
+                    .map(|item| {
+                        let g2_gen = G2Prepared::neg_generator();
+                        let pub_key_prepared = G2Prepared::from(&item.pk);
+                        Gt::multipairing(&[(&item.sig, g2_gen), (&item.msg, &pub_key_prepared)])
+                            .is_identity()
+                    })
+                    .collect()
+            };
+
+            let elapsed_ns = start.elapsed().as_nanos() as u64;
+            let mode = if GPU_ENABLED.load(Ordering::Relaxed) && batch_size > 1 {
+                "GPU"
+            } else {
+                "CPU"
+            };
+
+            let count = GPU_BATCH_COUNT.fetch_add(1, Ordering::Relaxed) + 1;
+            let total = GPU_BATCH_TOTAL_NS.fetch_add(elapsed_ns, Ordering::Relaxed) + elapsed_ns;
+            if count % 10 == 0 {
+                let avg_ms = (total as f64) / (count as f64) / 1_000_000.0;
+                eprintln!(
+                    "[GPU-CRYPTO] flush_batch #{count}: {batch_size} items, avg {avg_ms:.3}ms/batch ({mode})"
+                );
+            }
+
+            results
+        })
+    }
+}
