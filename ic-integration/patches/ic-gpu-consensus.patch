 ///
 /// The naive version of this function requires two pairings, but it
 /// is possible to use optimizations to reduce this overhead somewhat.
+/// GPU-accelerated G1 batch deserialization (point decompression).
+///
+/// Falls back to CPU if GPU unavailable or batch too small.
+/// Oracle-verified against ic_bls12_381::G1Affine::from_compressed.
+pub mod gpu_decompress {
+    use super::*;
+
+    /// Batch decompress G1 points using GPU.
+    /// Input: slice of 48-byte compressed BLS12-381 G1 points.
+    /// Returns Vec<G1Affine> or falls back to CPU.
+    pub fn batch_decompress_g1<B: AsRef<[u8]>>(
+        inputs: &[B],
+    ) -> Result<Vec<G1Affine>, PairingInvalidPoint> {
+        let n = inputs.len();
+
+        // Use GPU for batches of 8+ points
+        if n >= 8 && gpu_msm::gpu_available_internal() {
+            // Pack all compressed points into contiguous buffer
+            let mut compressed = Vec::with_capacity(n * 48);
+            for input in inputs {
+                let bytes = input.as_ref();
+                if bytes.len() != 48 {
+                    return Err(PairingInvalidPoint::InvalidPoint);
+                }
+                compressed.extend_from_slice(bytes);
+            }
+
+            if let Ok(points) = gpu_crypto::g1_decompress_batch(&compressed) {
+                // Wrap ic_bls12_381::G1Affine into our G1Affine
+                return Ok(points.into_iter().map(|p| G1Affine::new(p)).collect());
+            }
+            // GPU failed, fall through to CPU
+        }
+
+        // CPU fallback
+        let mut r = Vec::with_capacity(n);
+        for input in inputs {
+            r.push(G1Affine::deserialize(input)?);
+        }
+        Ok(r)
+    }
+}
