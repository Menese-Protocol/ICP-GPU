+/// Perform BLS signature verification (single, CPU path).
+///
+/// The naive version of this function requires two pairings, but it
+/// is possible to use optimizations to reduce this overhead somewhat.
+/// For batch verification with GPU acceleration, use `gpu_batch`.
 pub fn verify_bls_signature(
     signature: &G1Affine,
     public_key: &G2Affine,
     message: &G1Affine,
 ) -> bool {
-    // faster version of
-    // Gt::pairing(&signature, &G2Affine::generator()) == Gt::pairing(&message, &public_key)
+    use std::sync::atomic::{AtomicU64, Ordering};
+    static VERIFY_COUNT: AtomicU64 = AtomicU64::new(0);
+    static VERIFY_TOTAL_NS: AtomicU64 = AtomicU64::new(0);
+
+    let start = std::time::Instant::now();
+    // CPU path for single verification — GPU only wins with batching
+    let result = {
+        let g2_gen = G2Prepared::neg_generator();
+        let pub_key_prepared = G2Prepared::from(public_key);
+        Gt::multipairing(&[(signature, g2_gen), (message, &pub_key_prepared)]).is_identity()
+    };
+    let elapsed_ns = start.elapsed().as_nanos() as u64;
+
+    let count = VERIFY_COUNT.fetch_add(1, Ordering::Relaxed) + 1;
+    let total = VERIFY_TOTAL_NS.fetch_add(elapsed_ns, Ordering::Relaxed) + elapsed_ns;
+    if count % 100 == 0 {
+        let avg_ms = (total as f64) / (count as f64) / 1_000_000.0;
+        eprintln!("[GPU-CRYPTO] verify_bls_signature #{count}: avg {avg_ms:.3}ms (CPU-single)");
+    }
