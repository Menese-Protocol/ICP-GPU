+/// GPU-accelerated batch BLS signature verification.
+/// Accepts a batch of (signature, public_key, message) triples.
+/// Returns a Vec<bool> with verification results.
+/// Falls back to CPU if GPU is unavailable.
+pub fn verify_bls_signature_batch_gpu(items: &[(&G1Affine, &G2Affine, &G1Affine)]) -> Vec<bool> {
+    if items.is_empty() {
+        return vec![];
+    }
+
+    // Try GPU path
+    let g2_inner = ic_bls12_381::G2Prepared::from(ic_bls12_381::G2Affine::generator());
+    let sigs: Vec<ic_bls12_381::G1Affine> =
+        items.iter().map(|(s, _, _)| s.inner().clone()).collect();
+    // GPU expects negated message points (it checks e(sig,G2)*e(-msg,pk)==1)
+    let msgs: Vec<ic_bls12_381::G1Affine> = items
+        .iter()
+        .map(|(_, _, m)| (-ic_bls12_381::G1Projective::from(*m.inner())).into())
+        .collect();
+    let pk_preps: Vec<ic_bls12_381::G2Prepared> = items
+        .iter()
+        .map(|(_, pk, _)| ic_bls12_381::G2Prepared::from(*pk.inner()))
+        .collect();
+
+    match gpu_crypto::batch_bls_verify(&sigs, &msgs, &g2_inner, &pk_preps) {
+        Ok(results) => results,
+        Err(_) => {
+            // CPU fallback
+            items
+                .iter()
+                .map(|(sig, pk, msg)| verify_bls_signature(sig, pk, msg))
+                .collect()
+        }
+    }
+}
