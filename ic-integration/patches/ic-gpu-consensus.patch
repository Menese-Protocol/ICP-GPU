+/// GPU-accelerated Multi-Scalar Multiplication on G1.
+///
+/// Computes: result = sum(points[i] * scalars[i])
+/// Uses sppark Pippenger on GPU, falls back to CPU if unavailable.
+/// Oracle-verified against ic_bls12_381 muln_affine_vartime.
+pub mod gpu_msm {
+    use super::*;
+    use std::sync::atomic::{AtomicBool, Ordering};
+
+    static GPU_MSM_AVAILABLE: AtomicBool = AtomicBool::new(false);
+    static GPU_MSM_INIT_DONE: AtomicBool = AtomicBool::new(false);
+
+    fn ensure_init() {
+        if !GPU_MSM_INIT_DONE.swap(true, Ordering::Relaxed) {
+            match gpu_crypto::init() {
+                Ok(()) => {
+                    GPU_MSM_AVAILABLE.store(true, Ordering::Relaxed);
+                    eprintln!("[GPU-MSM] GPU MSM initialized");
+                }
+                Err(e) => {
+                    eprintln!("[GPU-MSM] GPU not available: {e}, using CPU MSM");
+                }
+            }
+        }
+    }
+
+    /// Check if GPU is available (for use by sibling modules)
+    pub(crate) fn gpu_available_internal() -> bool {
+        ensure_init();
+        GPU_MSM_AVAILABLE.load(Ordering::Relaxed)
+    }
+
+    /// GPU MSM: result = sum(points[i] * scalars[i])
+    /// Falls back to CPU muln_affine_vartime if GPU unavailable or batch too small.
+    pub fn msm_g1(points: &[G1Affine], scalars: &[Scalar]) -> G1Projective {
+        ensure_init();
+        let n = std::cmp::min(points.len(), scalars.len());
+
+        // GPU DISABLED FOR CPU BASELINE MEASUREMENT
+        if false && n >= 16 && GPU_MSM_AVAILABLE.load(Ordering::Relaxed) {
+            // gpu_crypto works with ic_bls12_381 types directly
+            // Our G1Affine wraps ic_bls12_381::G1Affine via inner()
+            let inner_pts: Vec<ic_bls12_381::G1Affine> =
+                points[..n].iter().map(|p| p.inner().clone()).collect();
+            let inner_scs: Vec<ic_bls12_381::Scalar> =
+                scalars[..n].iter().map(|s| s.inner().clone()).collect();
+            match gpu_crypto::msm_g1(&inner_pts, &inner_scs) {
+                Ok(result) => return G1Projective::new(
+                    ic_bls12_381::G1Projective::from(&result)
+                ),
+                Err(_) => {} // fall through to CPU
+            }
+        }
+
+        // CPU fallback
+        G1Projective::muln_affine_vartime(points, scalars)
+    }
+
+    /// GPU MSM from references (matching muln_affine_vartime_ref signature)
+    pub fn msm_g1_ref(points: &[&G1Affine], scalars: &[Scalar]) -> G1Projective {
+        ensure_init();
+        let n = std::cmp::min(points.len(), scalars.len());
+
+        if false && n >= 16 && GPU_MSM_AVAILABLE.load(Ordering::Relaxed) {
+            let inner_pts: Vec<ic_bls12_381::G1Affine> =
+                points[..n].iter().map(|p| p.inner().clone()).collect();
+            let inner_scs: Vec<ic_bls12_381::Scalar> =
+                scalars[..n].iter().map(|s| s.inner().clone()).collect();
+            match gpu_crypto::msm_g1(&inner_pts, &inner_scs) {
+                Ok(result) => return G1Projective::new(
+                    ic_bls12_381::G1Projective::from(&result)
+                ),
+                Err(_) => {}
+            }
+        }
+
+        G1Projective::muln_affine_vartime_ref(points, scalars)
+    }
+}
